---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import FeaturesGrid from '../islands/FeaturesGrid.tsx';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const features = [
  {
    icon: 'story' as const,
    title: t('features.story.title'),
    desc: t('features.story.desc'),
  },
  {
    icon: 'character' as const,
    title: t('features.character.title'),
    desc: t('features.character.desc'),
  },
  {
    icon: 'game' as const,
    title: t('features.game.title'),
    desc: t('features.game.desc'),
  },
  {
    icon: 'virtual' as const,
    title: t('features.virtual.title'),
    desc: t('features.virtual.desc'),
  },
  {
    icon: 'platform' as const,
    title: t('features.platform.title'),
    desc: t('features.platform.desc'),
  },
];
---

<section id="features" class="py-section-gap px-container-padding">
  <div class="max-w-[1440px] mx-auto">
    <div class="mb-16 text-center">
      <h2
        class="font-headline text-headline-lg mb-5 tracking-tight inline-block"
        style="background: linear-gradient(120deg, #ff5a00 0%, #ff8c4d 28%, #ffd9b8 60%, #ffffff 90%); -webkit-background-clip: text; background-clip: text; color: transparent; -webkit-text-fill-color: transparent;"
      >
        {t('features.title')}
      </h2>
      <p
        class="text-body-md text-on-surface-variant max-w-2xl mx-auto"
        style="letter-spacing: 0.08em; opacity: 0.55;"
      >
        {t('features.subtitle')}
      </p>
    </div>

    <FeaturesGrid features={features} client:visible />
  </div>
</section>
