---
import { useTranslations } from '../../i18n/utils';
import type { Lang, UIKey } from '../../i18n/ui';
import MuztrixGlyph from '../MuztrixGlyph.astro';
import LangSwitcher from './LangSwitcher.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const localeUrls: Record<Lang, string> = {
  'zh-TW': '/',
  en: '/en/',
  ja: '/ja/',
};

type NavItem = { labelKey: UIKey; href: string };

const navItems: NavItem[] = [
  { labelKey: 'nav.solutions', href: '#solutions' },
  { labelKey: 'nav.virtualHuman', href: '#virtual' },
  { labelKey: 'nav.game', href: '#game' },
  { labelKey: 'nav.comic', href: '#comic' },
  { labelKey: 'nav.about', href: '#about' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 px-5 py-5 transition-all duration-500"
  style="background: transparent;"
>
  <div
    class="flex items-center justify-between max-w-[1440px] mx-auto px-5"
  >
    <a href={localeUrls[lang]} class="wordmark">
      <MuztrixGlyph size={26} />
      <span>Muztrix</span>
    </a>

    <nav class="hidden md:flex gap-9 mx-header-nav">
      {
        navItems.map((it) => (
          <a
            href={it.href}
            class="text-[12px] font-medium uppercase transition-colors duration-200"
            style="letter-spacing: 0.16em; color: var(--color-bone-2); text-decoration: none;"
            onmouseenter="this.style.color='var(--color-cinnabar)'"
            onmouseleave="this.style.color='var(--color-bone-2)'"
          >
            {t(it.labelKey)}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-5">
      <LangSwitcher lang={lang} />
      <a
        href="#contact"
        class="hidden sm:inline-flex btn-v2 btn-v2--primary"
        style="padding: 12px 22px; font-size: 11px;"
      >
        {t('nav.contact')}
        <span class="arrow"></span>
      </a>
    </div>
  </div>
</header>

<script>
  // Scroll-aware header background
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 40) {
        header.style.background = 'rgba(14,11,8,0.78)';
        header.style.backdropFilter = 'blur(20px) saturate(140%)';
        (header.style as any).WebkitBackdropFilter =
          'blur(20px) saturate(140%)';
        header.style.borderBottom = '1px solid var(--bone-line)';
      } else {
        header.style.background = 'transparent';
        header.style.backdropFilter = 'none';
        (header.style as any).WebkitBackdropFilter = 'none';
        header.style.borderBottom = '1px solid transparent';
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
