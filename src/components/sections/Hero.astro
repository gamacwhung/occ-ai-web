---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import HeroVisual from '../islands/HeroVisual.tsx';
import HeroBackground from '../islands/HeroBackground.tsx';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  id="hero"
  class="relative min-h-screen overflow-hidden flex items-center"
>
  {/* Layer 0: atmospheric background — grid + particles (idle hydration) */}
  <HeroBackground client:idle />

  {/* Layer 1: Character — three-stage transformation (line art → color → neon) */}
  <HeroVisual
    lineSrc="/images/miyaki-draft.webp"
    colorSrc="/images/miyaki-full.webp"
    alt="Muztrix AI Virtual Human"
    client:visible
  />

  {/* Layer 2: Text overlay — z-20, edge slightly overlaps character */}
  <div
    class="relative z-20 max-w-[1440px] mx-auto px-container-padding pt-32 pb-20 w-full"
  >
    <div class="max-w-[680px]">
      <p
        class="text-label-sm uppercase tracking-[0.25em] text-primary mb-6 font-headline"
      >
        {t('hero.eyebrow')}
      </p>
      <h1
        class="font-headline text-[52px] lg:text-[80px] text-white leading-[1.02] mb-8 font-extrabold tracking-tight"
        style="text-shadow: 0 4px 40px rgba(0,0,0,0.6);"
      >
        {t('hero.title.line1')}<br />
        <span class="text-primary">{t('hero.title.line2')}</span>
      </h1>
      <p
        class="text-body-lg text-on-surface-variant max-w-xl mb-12 leading-relaxed"
        style="text-shadow: 0 2px 20px rgba(0,0,0,0.6);"
      >
        {t('hero.desc')}
      </p>

      <div class="flex flex-wrap gap-5">
        <a href="#cta" class="shimmer-btn shimmer-btn-primary">
          <span class="relative z-10">{t('hero.cta.primary')}</span>
          <span class="material-symbols-outlined relative z-10 text-[20px]">
            arrow_forward
          </span>
        </a>
        <button class="shimmer-btn shimmer-btn-glass">
          <span class="material-symbols-outlined relative z-10 text-[20px]">
            play_circle
          </span>
          <span class="relative z-10">{t('hero.cta.secondary')}</span>
        </button>
      </div>
    </div>
  </div>

  {/* Bottom fade — character/background blends into next section */}
  <div
    class="absolute bottom-0 left-0 right-0 h-[280px] pointer-events-none z-30"
    style="background: linear-gradient(to bottom, transparent 0%, rgba(10,10,12,0.6) 60%, #0a0a0c 100%);"
  >
  </div>
</section>

<style>
  /* Glassmorphism + shimmer button base */
  .shimmer-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 36px;
    border-radius: 12px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    overflow: hidden;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    isolation: isolate;
  }

  /* Shimmer sweep — light passes diagonally on hover */
  .shimmer-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      110deg,
      transparent 0%,
      transparent 35%,
      rgba(255, 255, 255, 0.18) 50%,
      transparent 65%,
      transparent 100%
    );
    transform: translateX(-100%);
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }
  .shimmer-btn:hover::before {
    transform: translateX(100%);
  }

  /* Primary — solid orange with neon halo */
  .shimmer-btn-primary {
    color: white;
    background: linear-gradient(135deg, #ff5a00 0%, #ff7a30 100%);
    border-color: rgba(255, 140, 80, 0.5);
    box-shadow:
      0 0 28px rgba(255, 90, 0, 0.4),
      0 1px 0 rgba(255, 255, 255, 0.15) inset,
      0 -1px 0 rgba(0, 0, 0, 0.2) inset;
  }
  .shimmer-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow:
      0 0 50px rgba(255, 90, 0, 0.65),
      0 1px 0 rgba(255, 255, 255, 0.2) inset,
      0 -1px 0 rgba(0, 0, 0, 0.2) inset;
  }

  /* Glass — frosted background with subtle border */
  .shimmer-btn-glass {
    color: white;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow:
      0 0 24px rgba(0, 0, 0, 0.3),
      0 1px 0 rgba(255, 255, 255, 0.08) inset;
  }
  .shimmer-btn-glass:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 140, 80, 0.45);
    transform: translateY(-2px);
    box-shadow:
      0 0 30px rgba(255, 90, 0, 0.18),
      0 1px 0 rgba(255, 255, 255, 0.1) inset;
  }
</style>
