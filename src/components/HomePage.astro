---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './sections/Header.astro';
import Hero from './sections/Hero.astro';
import Solutions from './sections/Solutions.astro';
import About from './sections/About.astro';
import VirtualHuman from './sections/VirtualHuman.astro';
import Comic from './sections/Comic.astro';
import Game from './sections/Game.astro';
import CTAFooter from './sections/CTAFooter.astro';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<BaseLayout>
  <div class="mx-root">
    <Header lang={lang} />
    <Hero lang={lang} />
    <Solutions lang={lang} />
    <VirtualHuman lang={lang} />
    <Game lang={lang} />
    <Comic lang={lang} />
    <About lang={lang} />
    <CTAFooter lang={lang} />
  </div>
</BaseLayout>

<style>
  /* Each artboard / page root becomes the container query target */
  .mx-root {
    container-type: inline-size;
    container-name: page;
  }
</style>
