---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="bento" class="py-section-gap px-container-padding relative">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col items-center mb-section-gap text-center">
      <span class="text-label-sm text-primary uppercase mb-4 tracking-[0.2em]">
        {t('bento.eyebrow')}
      </span>
      <h2
        class="font-headline text-headline-xl text-on-surface max-w-4xl leading-tight"
      >
        {t('bento.title.line1')}<br />
        {t('bento.title.line2')}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
      <!-- Large Capability Card -->
      <div
        class="md:col-span-8 glass-vessel p-12 rounded-xl group hover:border-primary/40 transition-all duration-700"
      >
        <div class="flex flex-col h-full justify-between">
          <div>
            <span
              class="material-symbols-outlined text-primary text-5xl mb-8 block"
              >neurology</span
            >
            <h3 class="font-headline text-headline-lg mb-6 text-white">
              {t('bento.neural.title')}
            </h3>
            <p class="text-body-lg text-on-surface-variant max-w-md leading-relaxed">
              {t('bento.neural.desc')}
            </p>
          </div>
          <div
            class="mt-12 flex items-center gap-4 text-primary text-label-sm tracking-[0.2em] uppercase cursor-pointer"
          >
            {t('bento.neural.cta')}
            <span class="material-symbols-outlined">north_east</span>
          </div>
        </div>
      </div>

      <!-- Small Capability Card -->
      <div
        class="md:col-span-4 glass-vessel p-10 rounded-xl flex flex-col items-center justify-center text-center"
      >
        <span class="material-symbols-outlined text-primary text-6xl mb-6"
          >cognition</span
        >
        <h4 class="font-headline text-headline-md mb-4 text-white">
          {t('bento.cognitive.title')}
        </h4>
        <p class="text-body-md text-on-surface-variant leading-relaxed">
          {t('bento.cognitive.desc')}
        </p>
      </div>
    </div>
  </div>
</section>
